# Server Configuration
PROJECT_NAME=job-scheduler
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
API_V1_STR=/api/v1
ADMIN_TOKEN=supersecret-dev-token
CORS_ORIGINS='["http://localhost:5173", "https://localhost:5173"]'

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/job_scheduler

# SMTP Configuration (For Alerts and Email Jobs)
SMTP_HOST=localhost
SMTP_PORT=8025
ALERT_EMAIL_TO=admin@localhost
ALERT_EMAIL_FROM=scheduler@localhost

# Scheduler Configuration
MAX_RETRIES=3
DLQ_ALERT_THRESHOLD=10
AGING_THRESHOLD_SECONDS=300
AGING_WEIGHT=1.0
WORKER_POLL_INTERVAL_SECONDS=2.0
SCHEDULED_JOB_CHECK_INTERVAL_SECONDS=5.0
AGING_RECALC_INTERVAL_SECONDS=60.0
